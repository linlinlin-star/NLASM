定义函数 平方(x):
    返回 x * x

定义函数 立方(x):
    返回 x * x * x

定义函数 绝对值(x):
    如果 x < 0:
        返回 -x
    返回 x

定义函数 最大公约数(a, b):
    当 b != 0:
        定义 temp = b
        b = a % b
        a = temp
    返回 a

定义函数 最小公倍数(a, b):
    返回 a * b / 最大公约数(a, b)

定义函数 阶乘(n):
    如果 n <= 1:
        返回 1
    返回 n * 阶乘(n - 1)

定义函数 斐波那契(n):
    如果 n <= 1:
        返回 n
    返回 斐波那契(n - 1) + 斐波那契(n - 2)

定义函数 是否素数(n):
    如果 n < 2:
        返回 假
    定义 i = 2
    当 i * i <= n:
        如果 n % i == 0:
            返回 假
        i = i + 1
    返回 真

定义函数 平方根(x):
    返回 __math_sqrt__(x)

定义函数 幂(x, y):
    返回 __math_pow__(x, y)

定义函数 正弦(x):
    返回 __math_sin__(x)

定义函数 余弦(x):
    返回 __math_cos__(x)

定义函数 正切(x):
    返回 __math_tan__(x)

定义函数 反正弦(x):
    返回 __math_asin__(x)

定义函数 反余弦(x):
    返回 __math_acos__(x)

定义函数 反正切(x):
    返回 __math_atan__(x)

定义函数 反正切2(y, x):
    返回 __math_atan2__(y, x)

定义函数 斜边(x, y):
    返回 __math_hypot__(x, y)

定义函数 自然对数(x):
    返回 __math_log__(x)

定义函数 对数(x, base):
    返回 __math_log__(x, base)

定义函数 二进制对数(x):
    返回 __math_log2__(x)

定义函数 十进制对数(x):
    返回 __math_log10__(x)

定义函数 上取整(x):
    返回 __math_ceil__(x)

定义函数 下取整(x):
    返回 __math_floor__(x)

定义函数 圆周率():
    返回 __math_pi__()

定义函数 自然常数():
    返回 __math_e__()

定义函数 角度转弧度(x):
    返回 __math_radians__(x)

定义函数 弧度转角度(x):
    返回 __math_degrees__(x)

定义函数 限制范围(x, lo, hi):
    如果 x < lo:
        返回 lo
    如果 x > hi:
        返回 hi
    返回 x

定义函数 符号(x):
    如果 x > 0:
        返回 1
    如果 x < 0:
        返回 -1
    返回 0

定义函数 平均值(arr):
    定义 s = 0
    定义 c = 0
    对于 arr 中的每个元素 x:
        s = s + x
        c = c + 1
    返回 s / c

定义函数 求和(arr):
    定义 s = 0
    对于 arr 中的每个元素 x:
        s = s + x
    返回 s
