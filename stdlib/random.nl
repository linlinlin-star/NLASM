定义函数 随机整数(a, b):
    返回 __random_int__(a, b)

定义函数 随机浮点():
    返回 __random_float__()

定义函数 随机选择(arr):
    返回 __random_choice__(arr)

定义函数 随机打乱(arr):
    返回 __random_shuffle__(arr)

定义函数 随机抽样(arr, k):
    返回 __random_sample__(arr, k)

定义函数 设置种子(seed):
    __random_seed__(seed)

定义函数 随机范围(a, b):
    返回 __random_int__(a, b)

定义函数 随机布尔():
    返回 __random_int__(0, 1) == 1
