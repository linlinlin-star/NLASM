定义函数 所有键(d):
    返回 __dict_keys__(d)

定义函数 所有值(d):
    返回 __dict_values__(d)

定义函数 所有项(d):
    返回 __dict_items__(d)

定义函数 获取(d, key, default):
    返回 __dict_get__(d, key, default)

定义函数 包含键(d, key):
    返回 __dict_has__(d, key)

定义函数 合并(d1, d2):
    返回 __dict_merge__(d1, d2)

定义函数 从列表创建(keys, values):
    返回 __dict_from_list__(keys, values)

定义函数 反转(d):
    返回 __dict_invert__(d)
