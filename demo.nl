定义函数 斐波那契(n):
    如果 n <= 0:
        返回 0
    如果 n == 1:
        返回 1
    返回 斐波那契(n - 1) + 斐波那契(n - 2)

定义函数 阶乘(n):
    如果 n <= 1:
        返回 1
    返回 n * 阶乘(n - 1)

定义函数 是否为素数(n):
    如果 n < 2:
        返回 假
    i = 2
    当 i * i <= n:
        如果 n % i == 0:
            返回 假
        i = i + 1
    返回 真

定义函数 主函数():
    输出("===== NLASM v0.8.0 演示 =====")
    输出("")

    输出("--- 斐波那契数列 ---")
    对于 i 在 范围(1, 11):
        输出("F(" + 字符串(i) + ") =", 斐波那契(i))

    输出("")
    输出("--- 阶乘 ---")
    对于 i 在 范围(1, 8):
        输出(字符串(i) + "! =", 阶乘(i))

    输出("")
    输出("--- 素数检测 ---")
    对于 i 在 范围(2, 21):
        如果 是否为素数(i):
            输出(字符串(i), "是素数")

    输出("")
    输出("===== 演示完成 =====")
    输出("nihao")

主函数()
